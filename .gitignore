# Generated by Cargo
# will have compiled files and executables
/target
**/target
.DS_Store

# These are backup files generated by rustfmt
**/*.rs.bk

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db

# Logs
*.log

# Build artifacts
dist/
build/

# Node modules (if using any JS tools)
node_modules/

# Environment variables
.env
.env.local

# Temporary files
*.tmp
*.bak

# Dioxus specific
.dioxus/

# Windows build directory (created by our script)
../scrabble-windows-build/

# Claude Code local settings/session state
.claude/

# PID files written by scripts/services.sh
.pid.server
.pid.web

# Local dev SQLite database — recreated fresh by persistence::migrate()
# on server startup (create_if_missing). Tracking this in git meant a
# `git checkout`/`git reset` on it silently reverted both data *and*
# schema together (no real migration system — see docs/operations.md),
# which twice caused "no such column" errors after an innocuous-looking
# checkout. Local dev data is disposable; there's nothing here worth
# committing.
data/*.sqlite3
data/*.sqlite3-wal
data/*.sqlite3-shm
